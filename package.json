{
  "name": "keepsake",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run --workspaces --if-present dev",
    "build": "npm -w @keepsake/shared run build && npm -w @keepsake/pwa run build && npm -w @keepsake/server run build",
    "test": "npm run --workspaces --if-present test",
    "start": "npm -w @keepsake/server run start"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4"
  }
}
